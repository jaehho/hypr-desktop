#!/usr/bin/env bash
set -euo pipefail

# hypr-desktop — Virtual desktop manager for Hyprland
#
# Each desktop owns 10 workspaces: (desk-1)*10+1 … desk*10.
# Workspaces round-robin across monitors in canonical order
# (external monitors sorted by x, laptop eDP/LVDS last):
#   ws 1,4,7,10 → mon[0];  ws 2,5,8 → mon[1];  ws 3,6,9 → mon[2].
#
# A background daemon (watch) listens for workspace changes and auto-switches
# the desktop context when a workspace in another desktop is focused.

PERSIST_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/hypr-desktops"
RUNTIME_DIR="/tmp/hypr-desktops-$(id -u)"

DESKTOP_FILE="$PERSIST_DIR/desktops"
CURRENT_FILE="$RUNTIME_DIR/current"
LAYOUT_FILE="$RUNTIME_DIR/layout"
LOCK_FILE="$RUNTIME_DIR/lock"

DESKTOP_OFFSET=10

# ── helpers ──────────────────────────────────────────────────────────

_init() {
    mkdir -p "$PERSIST_DIR" "$RUNTIME_DIR"
    [[ -f "$DESKTOP_FILE" ]] || echo "1:Main" > "$DESKTOP_FILE"
    [[ -f "$CURRENT_FILE" ]] || echo "1" > "$CURRENT_FILE"
    [[ -f "$LAYOUT_FILE" ]] || touch "$LAYOUT_FILE"
}

_current_id() {
    read -r id < "$CURRENT_FILE" 2>/dev/null && echo "$id" || echo "1"
}

_desk_name() {
    local id=$1
    local name
    name=$(grep "^${id}:" "$DESKTOP_FILE" 2>/dev/null | head -1 | cut -d: -f2- || true)
    echo "${name:-Desktop $id}"
}

_next_id() {
    local max
    max=$(cut -d: -f1 "$DESKTOP_FILE" | sort -n | tail -1)
    echo $(( max + 1 ))
}

_ws_id() {
    # desktop $1, local slot $2 (1-10) → global workspace id
    echo $(( ($1 - 1) * DESKTOP_OFFSET + $2 ))
}

_ws_to_desktop() {
    # global workspace id → desktop id
    echo $(( ($1 - 1) / DESKTOP_OFFSET + 1 ))
}

_monitors_json() {
    hyprctl monitors -j
}

_ordered_monitors() {
    # Canonical round-robin order: externals sorted by x, laptop (eDP/LVDS) last.
    local mon_data="$1"
    local laptop=""
    local -a externals=()
    while IFS= read -r name; do
        if [[ "$name" == eDP-* || "$name" == LVDS-* ]]; then
            laptop="$name"
        else
            externals+=("$name")
        fi
    done < <(echo "$mon_data" | jq -r 'sort_by(.x) | .[].name')
    [[ ${#externals[@]} -gt 0 ]] && printf '%s\n' "${externals[@]}"
    [[ -n "$laptop" ]] && echo "$laptop"
}

_signal_waybar() {
    pkill -RTMIN+8 waybar 2>/dev/null || true
}

_lock() {
    # Timestamp-based lock. The daemon skips events within 3s of the last write.
    # Call at the START and END of state-changing operations to cover the full
    # window including queued hyprland events that arrive after the batch.
    date +%s > "$LOCK_FILE"
}
_unlock() { rm -f "$LOCK_FILE"; }
_locked() {
    [[ -f "$LOCK_FILE" ]] || return 1
    local t
    t=$(cat "$LOCK_FILE" 2>/dev/null) || return 1
    (( $(date +%s) - t < 3 ))
}

# ── workspace-monitor mapping ───────────────────────────────────────

_ensure_mapping() {
    local desk=$1
    local mon_data=$2
    local batch=""
    local -a mons=()
    while IFS= read -r m; do mons+=("$m"); done < <(_ordered_monitors "$mon_data")
    local mon_count=${#mons[@]}
    (( mon_count == 0 )) && return
    for slot in $(seq 1 10); do
        local ws=$(_ws_id "$desk" "$slot")
        local mon_idx=$(( (slot - 1) % mon_count ))
        batch+="dispatch moveworkspacetomonitor ${ws} ${mons[$mon_idx]}; "
    done
    hyprctl --batch "$batch" >/dev/null 2>&1
}

# ── save / restore layout ───────────────────────────────────────────

_save_layout() {
    # Save per-monitor workspace for a desktop.
    # Only saves workspaces that actually belong to this desktop —
    # cross-desktop workspaces are skipped (restore uses defaults).
    local desk=$1
    local mon_data=$2

    sed -i "/^${desk}|/d" "$LAYOUT_FILE"

    local focused
    focused=$(echo "$mon_data" | jq -r '.[] | select(.focused) | .name')
    echo "${desk}|_focus|${focused}" >> "$LAYOUT_FILE"

    echo "$mon_data" | jq -r '.[] | "\(.name)|\(.activeWorkspace.id)"' \
    | while IFS='|' read -r mon ws; do
        local ws_desk
        ws_desk=$(_ws_to_desktop "$ws")
        [[ "$ws_desk" != "$desk" ]] && continue
        echo "${desk}|${mon}|${ws}" >> "$LAYOUT_FILE"
    done
}

_restore_layout() {
    # Two-phase restore: assign monitors first (silent), then activate (events).
    # This prevents intermediate focusmonitor events from leaking old-desktop
    # workspace IDs to the watch daemon.
    local desk=$1
    local mon_data=$2
    local batch=""
    local idx=0
    local -a targets=()

    while IFS= read -r mon; do
        idx=$((idx + 1))
        local saved default target
        saved=$(grep "^${desk}|${mon}|" "$LAYOUT_FILE" 2>/dev/null | tail -1 | cut -d'|' -f3 || true)
        default=$(_ws_id "$desk" "$idx")
        target="${saved:-$default}"
        batch+="dispatch moveworkspacetomonitor ${target} ${mon}; "
        targets+=("$target")
    done < <(_ordered_monitors "$mon_data")

    for target in "${targets[@]}"; do
        batch+="dispatch workspace ${target}; "
    done

    local focus_mon
    focus_mon=$(grep "^${desk}|_focus|" "$LAYOUT_FILE" 2>/dev/null | tail -1 | cut -d'|' -f3 || true)
    [[ -n "${focus_mon:-}" ]] && batch+="dispatch focusmonitor ${focus_mon}; "

    [[ -n "$batch" ]] && hyprctl --batch "$batch" >/dev/null 2>&1
}

# ── commands ─────────────────────────────────────────────────────────

cmd_switch() {
    # Single code path for ALL desktop switches (daemon, CLI, TUI).
    local target="${1:?desktop id or name required}"

    if [[ ! "$target" =~ ^[0-9]+$ ]]; then
        local resolved
        resolved=$(grep -i ":${target}$" "$DESKTOP_FILE" 2>/dev/null | head -1 | cut -d: -f1 || true)
        [[ -z "$resolved" ]] && { echo "Desktop '$target' not found" >&2; return 1; }
        target=$resolved
    fi

    local current
    current=$(_current_id)
    [[ "$target" == "$current" ]] && return

    grep -q "^${target}:" "$DESKTOP_FILE" 2>/dev/null \
        || { echo "Desktop $target not found" >&2; return 1; }

    _lock
    local mon_data
    mon_data=$(_monitors_json)
    _save_layout "$current" "$mon_data"
    echo "$target" > "$CURRENT_FILE"
    _restore_layout "$target" "$mon_data"
    _lock   # refresh: cover queued events arriving after the batch
    _signal_waybar
}

cmd_next() {
    local current ids next
    current=$(_current_id)
    ids=$(cut -d: -f1 "$DESKTOP_FILE" | sort -n)
    next=$(echo "$ids" | grep -A1 "^${current}$" | tail -1)
    [[ "$next" == "$current" ]] && next=$(echo "$ids" | head -1)
    cmd_switch "$next"
}

cmd_prev() {
    local current ids prev
    current=$(_current_id)
    ids=$(cut -d: -f1 "$DESKTOP_FILE" | sort -n)
    prev=$(echo "$ids" | grep -B1 "^${current}$" | head -1)
    [[ "$prev" == "$current" ]] && prev=$(echo "$ids" | tail -1)
    cmd_switch "$prev"
}

cmd_ws() {
    local target
    target=$(( ($(_current_id) - 1) * DESKTOP_OFFSET + $1 ))
    exec hyprctl dispatch workspace "$target"
}

cmd_movews() {
    local target
    target=$(( ($(_current_id) - 1) * DESKTOP_OFFSET + $1 ))
    exec hyprctl dispatch movetoworkspace "$target"
}

cmd_movesilent() {
    local target
    target=$(( ($(_current_id) - 1) * DESKTOP_OFFSET + $1 ))
    exec hyprctl dispatch movetoworkspacesilent "$target"
}

cmd_moveall() {
    local desk target
    desk=$(_current_id)
    target=$(_ws_id "$desk" "$1")
    if [[ -x "$HOME/.local/bin/hypr-move-all-to-workspace" ]]; then
        exec "$HOME/.local/bin/hypr-move-all-to-workspace" "$target"
    fi
    local current_ws
    current_ws=$(hyprctl activewindow -j 2>/dev/null | jq -r '.workspace.id')
    hyprctl clients -j | jq -r ".[] | select(.workspace.id == $current_ws) | .address" \
    | while read -r addr; do
        [[ -z "$addr" ]] && continue
        hyprctl dispatch movetoworkspacesilent "$target,address:$addr" >/dev/null 2>&1
    done
}

cmd_create() {
    local name="${1:?name required}"
    local id
    id=$(_next_id)
    echo "${id}:${name}" >> "$DESKTOP_FILE"
    cmd_switch "$id"
}

cmd_rename() {
    local name="${1:?name required}" current
    current=$(_current_id)
    (( current == 1 )) && { echo "Desktop 1 (Main) cannot be renamed" >&2; return 1; }
    sed -i "s/^${current}:.*/${current}:${name}/" "$DESKTOP_FILE"
    _signal_waybar
}

cmd_delete() {
    # delete [id] — delete a desktop by id (default: current).
    local victim="${1:-$(_current_id)}"

    grep -q "^${victim}:" "$DESKTOP_FILE" 2>/dev/null \
        || { echo "Desktop $victim not found" >&2; return 1; }
    (( victim == 1 )) && { echo "Desktop 1 (Main) cannot be deleted" >&2; return 1; }
    local count
    count=$(wc -l < "$DESKTOP_FILE")
    (( count < 2 )) && { echo "Cannot delete the only desktop" >&2; return 1; }

    _lock

    # Neighbor receives windows: prefer previous, fall back to next
    local ids neighbor
    ids=$(cut -d: -f1 "$DESKTOP_FILE" | sort -n)
    neighbor=$(echo "$ids" | grep -B1 "^${victim}$" | head -1)
    [[ "$neighbor" == "$victim" ]] && neighbor=$(echo "$ids" | grep -A1 "^${victim}$" | tail -1)

    # Move windows
    local clients
    clients=$(hyprctl clients -j)
    for ws in $(seq 1 10); do
        local src=$(_ws_id "$victim" "$ws")
        local dst=$(_ws_id "$neighbor" "$ws")
        echo "$clients" | jq -r --argjson s "$src" \
            '.[] | select(.workspace.id == $s) | .address' | while read -r addr; do
            [[ -z "$addr" ]] && continue
            hyprctl dispatch movetoworkspacesilent "$dst,address:$addr" >/dev/null 2>&1
        done
    done

    # If deleting the active desktop, switch monitors to the neighbor
    local current=$(_current_id)
    if [[ "$victim" == "$current" ]]; then
        local mon_data=$(_monitors_json)
        echo "$neighbor" > "$CURRENT_FILE"
        _restore_layout "$neighbor" "$mon_data"
    fi

    sed -i "/^${victim}:/d" "$DESKTOP_FILE"
    sed -i "/^${victim}|/d" "$LAYOUT_FILE"
    _lock   # refresh
    _signal_waybar

    _do_compact
}

_do_compact() {
    local clients
    clients=$(hyprctl clients -j)
    local -a occupied=()
    while IFS=: read -r id name; do
        local ws_min=$(_ws_id "$id" 1)
        local ws_max=$(_ws_id "$id" 10)
        local wcount
        wcount=$(echo "$clients" | jq --argjson min "$ws_min" --argjson max "$ws_max" \
            '[.[] | select(.workspace.id >= $min and .workspace.id <= $max)] | length')
        (( wcount > 0 )) && occupied+=("$id")
    done < "$DESKTOP_FILE"
    (( ${#occupied[@]} == 0 )) && occupied=("$(head -1 "$DESKTOP_FILE" | cut -d: -f1)")

    local needs_work=false
    local total
    total=$(wc -l < "$DESKTOP_FILE")
    for ((i=0; i<${#occupied[@]}; i++)); do
        (( occupied[i] != i + 1 )) && { needs_work=true; break; }
    done
    ! $needs_work && (( total == ${#occupied[@]} )) && return

    local old_current=$(_current_id) new_current=1
    for ((i=0; i<${#occupied[@]}; i++)); do
        [[ "${occupied[$i]}" == "$old_current" ]] && new_current=$((i + 1))
    done

    for ((i=0; i<${#occupied[@]}; i++)); do
        local old_id=${occupied[$i]} new_id=$((i + 1))
        (( old_id == new_id )) && continue
        for ws in $(seq 1 10); do
            local src=$(_ws_id "$old_id" "$ws") dst=$(_ws_id "$new_id" "$ws")
            echo "$clients" | jq -r --argjson s "$src" \
                '.[] | select(.workspace.id == $s) | .address' | while read -r addr; do
                [[ -z "$addr" ]] && continue
                hyprctl dispatch movetoworkspacesilent "$dst,address:$addr" >/dev/null 2>&1
            done
        done
    done

    local tmpfile
    tmpfile=$(mktemp)
    for ((i=0; i<${#occupied[@]}; i++)); do
        echo "$((i + 1)):$(_desk_name "${occupied[$i]}")" >> "$tmpfile"
    done
    mv "$tmpfile" "$DESKTOP_FILE"
    echo "$new_current" > "$CURRENT_FILE"
    > "$LAYOUT_FILE"

    local mon_data
    mon_data=$(_monitors_json)
    _ensure_mapping "$new_current" "$mon_data"
    _restore_layout "$new_current" "$mon_data"
    _lock   # refresh: cover queued events
    _signal_waybar
}

cmd_compact() {
    _lock
    _do_compact
}

cmd_tab() {
    local direction="${1:-next}"
    local mon_json current_ws current_mon desk
    mon_json=$(_monitors_json)
    current_mon=$(echo "$mon_json" | jq -r '.[] | select(.focused) | .name')
    current_ws=$(echo "$mon_json" | jq -r '.[] | select(.focused) | .activeWorkspace.id')
    desk=$(_current_id)

    local -a mons=()
    while IFS= read -r m; do mons+=("$m"); done < <(_ordered_monitors "$mon_json")
    local mon_count=${#mons[@]} mon_idx=0
    for ((i=0; i<mon_count; i++)); do
        [[ "${mons[$i]}" == "$current_mon" ]] && { mon_idx=$i; break; }
    done

    local -a slots=()
    for slot in $(seq 1 10); do
        (( (slot - 1) % mon_count == mon_idx )) && slots+=($(_ws_id "$desk" "$slot"))
    done

    local count=${#slots[@]}
    (( count <= 1 )) && return
    local cur_idx=0
    for ((i=0; i<count; i++)); do
        (( slots[i] == current_ws )) && { cur_idx=$i; break; }
    done

    local target_idx
    if [[ "$direction" == "next" ]]; then
        target_idx=$(( (cur_idx + 1) % count ))
    else
        target_idx=$(( (cur_idx - 1 + count) % count ))
    fi
    hyprctl dispatch workspace "${slots[$target_idx]}" >/dev/null
}

cmd_sendtodesktop() {
    local target_desk="${1:?desktop required}"
    local current_desk=$(_current_id)

    if [[ "$target_desk" == "next" || "$target_desk" == "prev" ]]; then
        local ids
        ids=$(cut -d: -f1 "$DESKTOP_FILE" | sort -n)
        if [[ "$target_desk" == "next" ]]; then
            target_desk=$(echo "$ids" | grep -A1 "^${current_desk}$" | tail -1)
            [[ "$target_desk" == "$current_desk" ]] && target_desk=$(echo "$ids" | head -1)
        else
            target_desk=$(echo "$ids" | grep -B1 "^${current_desk}$" | head -1)
            [[ "$target_desk" == "$current_desk" ]] && target_desk=$(echo "$ids" | tail -1)
        fi
    fi
    grep -q "^${target_desk}:" "$DESKTOP_FILE" 2>/dev/null \
        || { echo "Desktop $target_desk not found" >&2; return 1; }

    local current_ws
    current_ws=$(hyprctl activewindow -j | jq -r '.workspace.id')
    [[ -z "$current_ws" || "$current_ws" == "null" ]] && return
    local slot=$(( (current_ws - 1) % DESKTOP_OFFSET + 1 ))
    hyprctl dispatch movetoworkspacesilent "$(_ws_id "$target_desk" "$slot")" >/dev/null
}

cmd_current() {
    local id name
    id=$(_current_id)
    name=$(_desk_name "$id")
    name=${name//\\/\\\\}
    name=${name//\"/\\\"}
    printf '{"text": "%s", "tooltip": "Desktop %s: %s\\nSuper+D to switch", "class": "desktop-%s"}\n' \
        "$name" "$id" "$name" "$id"
}

cmd_list() { cat "$DESKTOP_FILE"; }

# ── watch daemon ────────────────────────────────────────────────────
#
# Design: debounce at the event-loop level, not inside handlers.
# On a workspace event, drain the socket for 300ms to coalesce bursts.
# If configreloaded arrives during the burst, cancel the workspace
# switch and re-enforce the current desktop instead.
# All actual switching goes through cmd_switch (single code path).

cmd_watch() {
    local socket="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
    [[ -S "$socket" ]] || { echo "Hyprland IPC socket not found: $socket" >&2; exit 1; }
    command -v socat >/dev/null || { echo "socat required for watch mode" >&2; exit 1; }

    local pidfile="$RUNTIME_DIR/watch.pid"
    if [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile" 2>/dev/null)" 2>/dev/null; then
        echo "Watch daemon already running (PID $(cat "$pidfile"))" >&2
        return 1
    fi
    echo $$ > "$pidfile"
    trap 'rm -f "$pidfile"' EXIT

    socat -U - "UNIX-CONNECT:$socket" | while true; do
        IFS= read -r event || break

        case "$event" in
            workspace\>\>*)
                # Debounce: drain socket for 300ms, coalesce workspace events
                local last_ws="${event#workspace>>}"
                local got_reload=false
                while IFS= read -t 0.3 -r event; do
                    case "$event" in
                        workspace\>\>*) last_ws="${event#workspace>>}" ;;
                        configreloaded\>\>*) got_reload=true ;;
                    esac
                done

                if $got_reload; then
                    _on_config_reload || true
                else
                    _on_workspace_change "$last_ws" || true
                fi
                ;;
            configreloaded\>\>*)
                _on_config_reload || true
                ;;
        esac
    done
}

_on_config_reload() {
    _locked && return
    local desk=$(_current_id)
    local mon_data=$(_monitors_json)
    _ensure_mapping "$desk" "$mon_data"
    _restore_layout "$desk" "$mon_data"
    _signal_waybar
}

_on_workspace_change() {
    local ws_name="$1"
    _locked && return
    [[ "$ws_name" == special:* ]] && return

    local ws_id
    if [[ "$ws_name" =~ ^[0-9]+$ ]]; then
        ws_id="$ws_name"
    else
        ws_id=$(hyprctl workspaces -j | jq -r --arg n "$ws_name" \
            '.[] | select(.name == $n) | .id // empty')
        [[ -z "$ws_id" ]] && return
    fi

    local target_desk=$(_ws_to_desktop "$ws_id")
    local current=$(_current_id)
    [[ "$target_desk" == "$current" ]] && return

    # Final verification: check the actual focused workspace right now
    local verify_ws
    verify_ws=$(hyprctl activeworkspace -j | jq -r '.id')
    local verify_desk=$(_ws_to_desktop "$verify_ws")
    [[ "$verify_desk" == "$current" ]] && return

    grep -q "^${verify_desk}:" "$DESKTOP_FILE" 2>/dev/null || return

    # Use cmd_switch — single code path for all desktop switches
    cmd_switch "$verify_desk"
}

# ── main ─────────────────────────────────────────────────────────────

[[ -f "$CURRENT_FILE" ]] || _init

# Desktop 1 is always "Main"
grep -q '^1:Main$' "$DESKTOP_FILE" 2>/dev/null || sed -i 's/^1:.*$/1:Main/' "$DESKTOP_FILE"

case "${1:-}" in
    switch)         cmd_switch "${2:-}" ;;
    next)           cmd_next ;;
    prev)           cmd_prev ;;
    ws)             cmd_ws "${2:?workspace number required}" ;;
    movews)         cmd_movews "${2:?workspace number required}" ;;
    movesilent)     cmd_movesilent "${2:?workspace number required}" ;;
    moveall)        cmd_moveall "${2:?workspace number required}" ;;
    create)         cmd_create "${2:-}" ;;
    rename)         cmd_rename "${2:-}" ;;
    delete)         cmd_delete "${2:-}" ;;
    compact)        cmd_compact ;;
    tab)            cmd_tab "${2:-next}" ;;
    sendtodesktop)  cmd_sendtodesktop "${2:?target required (next|prev|N)}" ;;
    current)        cmd_current ;;
    list)           cmd_list ;;
    watch)          cmd_watch ;;
    init)           _init ;;
    *)              echo "Usage: hypr-desktop {switch|next|prev|ws|movews|movesilent|moveall|create|rename|delete|compact|tab|sendtodesktop|current|list|watch|init}" >&2
                    exit 1 ;;
esac
